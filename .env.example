# Copy this file to .env and fill in the values. Do NOT commit .env.

# Adzuna API (register at https://developer.adzuna.com/ for credentials)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Anthropic API: needed ONLY with SCORER_BACKEND="anthropic_api" in config.py.
# With the default "claude_cli" (uses the subscription via the claude CLI) leave
# it empty.
# ANTHROPIC_API_KEY=
